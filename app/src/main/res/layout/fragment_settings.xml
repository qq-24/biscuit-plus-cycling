<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_display_items"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <CheckBox
            android:id="@+id/check_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_speed"
            android:checked="true"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/check_cadence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_cadence"
            android:checked="true"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/check_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_distance"
            android:checked="true"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/check_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_time"
            android:checked="true"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/check_moving_duration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_moving_duration"
            android:checked="false"
            android:textSize="14sp" />

        <CheckBox
            android:id="@+id/check_avg_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_avg_speed"
            android:checked="false"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 仪表盘标签字号 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="仪表盘标签字号"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="小"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seekbar_label_size"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="20"
            android:progress="4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_label_size_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10sp"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="36dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 仪表盘数字粗细 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数字粗细"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seekbar_font_weight"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="8"
            android:progress="6" />

        <TextView
            android:id="@+id/tv_font_weight_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="700 Bold"
            android:textSize="14sp"
            android:layout_marginStart="8dp"
            android:minWidth="100dp" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_update_interval"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_update_interval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio_interval_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 秒"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_interval_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 秒"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_interval_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5 秒"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- GPS 定位参数 Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_gps_params"
        android:textColor="?attr/colorOnSurface"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:layout_marginTop="8dp" />

    <!-- GPS 更新频率 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_gps_interval"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_gps_interval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio_gps_interval_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 秒"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_interval_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 秒"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_interval_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5 秒"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- 最小位移距离 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_gps_min_distance"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_gps_min_distance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio_gps_distance_0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0 米（无筛选）"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_distance_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1 米"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_distance_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3 米"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_distance_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5 米"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- 精度筛选开关 + 阈值 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_gps_accuracy_filter"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_accuracy_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/radio_gps_accuracy_threshold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_gps_accuracy_threshold"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <RadioButton
            android:id="@+id/radio_gps_accuracy_10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="10 米"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_accuracy_20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="20 米"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_gps_accuracy_50"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="50 米"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- 低速过滤开关 + 阈值 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_gps_low_speed_filter"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_low_speed_filter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_low_speed_threshold"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_gps_low_speed_threshold"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/edit_low_speed_threshold"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:text="3"
            android:textSize="14sp"
            android:gravity="center"
            android:importantForAutofill="no" />
    </LinearLayout>

    <!-- 自动暂停 Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/settings_auto_pause"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_auto_pause"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_auto_pause_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_auto_pause_speed"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/edit_auto_pause_speed"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="3"
                android:textSize="14sp"
                android:gravity="center"
                android:importantForAutofill="no" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_auto_pause_delay"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/edit_auto_pause_delay"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:text="10"
                android:textSize="14sp"
                android:gravity="center"
                android:importantForAutofill="no" />
        </LinearLayout>

        <!-- 自动恢复冷却时间 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="自动恢复冷却时间"
            android:textColor="?attr/colorOnSurface"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="手动暂停后，需等待此时间才会自动恢复骑行"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekbar_cooldown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="55"
                android:progress="5" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="60"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />

            <TextView
                android:id="@+id/tv_cooldown_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 秒"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                android:minWidth="40dp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- 低速提醒 Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="低速提醒"
            android:textColor="?attr/colorOnSurface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_low_speed_alert"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_low_speed_alert_settings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="低速阈值 (km/h)"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/edit_low_speed_alert_threshold"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="10"
                android:hint="km/h"
                android:textSize="14sp"
                android:gravity="center"
                android:importantForAutofill="no" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_low_speed_alert_hint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="低于自动暂停阈值时不会触发提醒"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="光晕宽度"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekbar_glow_width"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="55"
                android:progress="15" />

            <TextView
                android:id="@+id/tv_glow_width_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20dp"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:minWidth="48dp" />
        </LinearLayout>

        <!-- 震动频率 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="提醒时长"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekbar_vibration_frame_interval"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="17"
                android:progress="3" />

            <TextView
                android:id="@+id/tv_vibration_frame_interval_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="每6帧"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:minWidth="48dp" />
        </LinearLayout>

        <!-- 间隔时长 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="间隔时长"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp"
                android:layout_marginEnd="8dp" />

            <SeekBar
                android:id="@+id/seekbar_alert_gap_interval"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="17"
                android:progress="3" />

            <TextView
                android:id="@+id/tv_alert_gap_interval_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3.0秒"
                android:textSize="14sp"
                android:layout_marginStart="8dp"
                android:minWidth="48dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 双击缩放灵敏度 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_zoom_sensitivity"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="低"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seekbar_zoom_sensitivity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="250"
            android:progress="150" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="高"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_zoom_sensitivity_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="150"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="30dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 地图瓦片缩放 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_tile_scale"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"
        android:layout_marginTop="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="清晰"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <SeekBar
            android:id="@+id/seekbar_tile_scale"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:max="20"
            android:progress="10" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大字"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:id="@+id/tv_tile_scale_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1.5"
            android:textColor="?attr/colorOnSurface"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="36dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 地图类型 Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_map_type"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="8dp" />

    <RadioGroup
        android:id="@+id/radio_map_type"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/radio_map_vector"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_map_vector"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_map_satellite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_map_satellite"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_map_terrain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_map_terrain"
            android:textSize="14sp" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/settings_theme"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <RadioGroup
        android:id="@+id/radio_theme"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/colorSurfaceVariant"
        android:padding="8dp">

        <RadioButton
            android:id="@+id/radio_theme_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_light"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_theme_dark"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_dark"
            android:checked="true"
            android:textSize="14sp" />

        <RadioButton
            android:id="@+id/radio_theme_oled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_theme_oled"
            android:textSize="14sp" />
    </RadioGroup>

    <!-- Debug section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="调试"
        android:textColor="?attr/colorOnSurface"
        android:textSize="16sp"
        android:textStyle="bold" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_mock_gps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="模拟GPS（电脑WSAD控制，需重启记录）"
        android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
